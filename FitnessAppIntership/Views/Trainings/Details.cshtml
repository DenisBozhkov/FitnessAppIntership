@using FitnessAppIntership.Services.Interfaces
@model FitnessAppIntership.Data.Entities.TrainingEntity
@inject ISubscriptionService service

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Details</h1>

<div>
    <h4>Training</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Training Type
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Type.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StartTime)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StartTime)
        </dd>
        <dt class="col-sm-2">
            Coach
        </dt>
        <dd class="col-sm-10">
            @string.Format("{0} {1} {2}", Model.Coach.FirstName, Model.Coach.SecondName, Model.Coach.LastName)
        </dd>
        <dt class="col-sm-2">
            Hall
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Hall.Name)
        </dd>
    </dl>
    <table class="table">
    <thead>
        <tr>
            <th>
                Enrolled Members
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Members) {
        <tr>
            <td>
                @string.Format("{0} {1} {2}", item.FirstName, item.SecondName, item.LastName)
            </td>
            <td>
            </td>
        </tr>
}
    </tbody>
</table>
</div>
<div>
    <a asp-action="Index">Back to List</a>
</div>
